from geometry_msgs.msg import PointStamped
import tf2_geometry_msgs  # important - needed for do_transform_point

# Create a point in odom frame
point_in_odom = PointStamped()
point_in_odom.header.frame_id = 'odom'
point_in_odom.header.stamp = self.get_clock().now().to_msg()
point_in_odom.point.x = 1.0
point_in_odom.point.y = 2.0
point_in_odom.point.z = 0.0

# Look up transform from odom to map
transform = self.tf_buffer.lookup_transform(
    'map',          # target frame
    'odom',         # source frame
    rclpy.time.Time(),
    rclpy.duration.Duration(seconds=0.2)
)

# Apply the transform
point_in_map = tf2_geometry_msgs.do_transform_point(point_in_odom, transform)
